rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Chats collection
    match /chats/{chatId} {
      allow read: if request.auth != null && (
        resource.data.type == 'global' ||
        (resource.data.participants is list && request.auth.uid in resource.data.participants) ||
        // admin role check
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      // Only allow creation if authenticated (creation logic enforced on client/service)
      allow create: if request.auth != null;
      // Prevent arbitrary updates to `lastMessage` from clients; allow only specific fields
      allow update: if request.auth != null && (
        // allow admins to update any chat
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null && (
          // allow if parent chat is global or contains the user or admin
          get(/databases/$(database)/documents/chats/$(chatId)).data.type == 'global' ||
          (get(/databases/$(database)/documents/chats/$(chatId)).data.participants is list && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );

        allow create: if request.auth != null && request.auth.uid == request.resource.data.senderId && (
          // sender must be participant of chat or chat is global or sender is admin
          get(/databases/$(database)/documents/chats/$(chatId)).data.type == 'global' ||
          (get(/databases/$(database)/documents/chats/$(chatId)).data.participants is list && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );

        // Prevent clients from deleting or modifying messages (optional)
        allow delete, update: if false;
      }
    }
  }
}
