rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).role == 'admin';
    }

    function isConsultor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).role == 'consultor';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isConsultantOf(userId) {
      return isConsultor()
        && exists(/databases/$(database)/documents/users/$(userId))
        && userDoc(userId).consultantId == request.auth.uid;
    }

    function canAccessUserData(userId) {
      return isOwner(userId) || isConsultantOf(userId) || isAdmin();
    }

    function ownsUserDocument() {
      return isSignedIn()
        && (
          !('userId' in request.resource.data)
          || request.resource.data.userId == request.auth.uid
          || isConsultantOf(request.resource.data.userId)
          || isAdmin()
        );
    }

    function canReadUserDocument() {
      return isSignedIn()
        && (
          !('userId' in resource.data)
          || canAccessUserData(resource.data.userId)
        );
    }

    function canGetUserDocument() {
      return isSignedIn()
        && (
          resource == null
          || !('userId' in resource.data)
          || canAccessUserData(resource.data.userId)
        );
    }

    function canGetChat() {
      return isSignedIn() && (
        resource == null
        || resource.data.type == 'global'
        || request.auth.uid in resource.data.participants
      );
    }

    function parentChatData(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId)).data;
    }

    function canAccessChat(chatId) {
      let chat = parentChatData(chatId);
      return chat.type == 'global'
        || request.auth.uid in chat.participants;
    }

    function canWriteUserDocument() {
      return isSignedIn()
        && (
          !('userId' in resource.data)
          || canAccessUserData(resource.data.userId)
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin() || isConsultantOf(userId);
      allow delete: if isAdmin();

      match /planning/{planningId} {
        allow get, write: if canAccessUserData(userId);
        allow list: if canAccessUserData(userId);
      }
    }

    match /incomes/{docId} {
      allow get: if canGetUserDocument();
      allow list: if canReadUserDocument();
      allow create: if ownsUserDocument();
      allow update, delete: if canWriteUserDocument();
    }

    match /expenses/{docId} {
      allow get: if canGetUserDocument();
      allow list: if canReadUserDocument();
      allow create: if ownsUserDocument();
      allow update, delete: if canWriteUserDocument();
    }

    match /budgets/{docId} {
      allow get: if canGetUserDocument();
      allow list: if canReadUserDocument();
      allow create: if ownsUserDocument();
      allow update, delete: if canWriteUserDocument();
    }

    match /goals/{docId} {
      allow get: if canGetUserDocument();
      allow list: if canReadUserDocument();
      allow create: if ownsUserDocument();
      allow update, delete: if canWriteUserDocument();
    }

    match /activities/{docId} {
      allow get: if canGetUserDocument();
      allow list: if canReadUserDocument();
      allow create: if ownsUserDocument();
      allow update, delete: if canWriteUserDocument();
    }

    match /bills/{docId} {
      allow get: if canGetUserDocument();
      allow list: if canReadUserDocument();
      allow create: if ownsUserDocument();
      allow update, delete: if canWriteUserDocument();
    }

    match /wishlists/{docId} {
      allow get: if canGetUserDocument();
      allow list: if canReadUserDocument();
      allow create: if ownsUserDocument();
      allow update, delete: if canWriteUserDocument();
    }

    match /creditCards/{docId} {
      allow get: if canGetUserDocument();
      allow list: if canReadUserDocument();
      allow create: if ownsUserDocument();
      allow update, delete: if canWriteUserDocument();
    }

    match /recommendations/{docId} {
      allow get: if canGetUserDocument();
      allow list: if canReadUserDocument();
      allow create: if ownsUserDocument();
      allow update, delete: if canWriteUserDocument();
    }

    match /categories/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /chats/{chatId} {
      allow get: if canGetChat();
      allow list: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        (
          resource.data.type == 'global'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'lastReadBy'])
        )
        || (
          request.auth.uid in resource.data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'lastReadBy'])
        )
      );

      match /messages/{messageId} {
        allow read: if canAccessChat(chatId);

        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.senderId
          && canAccessChat(chatId);

        allow delete, update: if false;
      }
    }
  }
}
